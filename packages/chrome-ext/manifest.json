{
  "manifest_version": 3,
  "name": "WorldMonitor — Intelligence Terminal",
  "short_name": "WorldMonitor",
  "version": "1.2.0",
  "description": "One-click access to the WorldMonitor multi-agent OSINT terminal.",
  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open WorldMonitor",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "permissions": [],
  "host_permissions": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "homepage_url": "https://worldmonitor-core.vercel.app"
}
