# WorldMonitor Core Environment Configuration

# Server Configuration
PORT=8080
DATABASE_URL=sqlite:./worldmonitor.db

# AI API Keys
GROQ_API_KEY=your_groq_api_key_here

# Free Tier Limits
MAX_ALERTS_FREE=3

# Stripe Billing (price tiers: Free / Pro / Enterprise)
#
# Two ways to collect payment — pick either (or both):
#
# (A) Hosted Payment Link — simplest, NO secret key needed. Checkout redirects
#     to this URL with ?client_reference_id=<user>. Pro defaults to a built-in
#     link; override here. (Public, shareable URLs — safe to commit.)
STRIPE_PAYMENT_LINK_PRO=https://buy.stripe.com/6oU14neX647kcaI29Z0oM00
STRIPE_PAYMENT_LINK_ENTERPRISE=
#
# (B) API Checkout Sessions — used only when no Payment Link is set for the
#     tier. Requires the secret key + recurring price ids.
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
#
# Publishable key (pk_live_… / pk_test_…) — PUBLIC by design; safe to expose to
# browsers. Served by GET /api/billing/config for future client-side Stripe.js.
# Optional: the current Payment Link / hosted Checkout flow does not need it.
STRIPE_PUBLISHABLE_KEY=
#
# Webhook signing secret — REQUIRED for auto-upgrade on payment, with either
# method. Point a Stripe webhook at /api/billing/webhook and paste its secret.
STRIPE_WEBHOOK_SECRET=
#
# Public base URL used to build Checkout success/cancel redirect links.
APP_BASE_URL=http://localhost:8080

# Optional: For production deployment
# RUST_LOG=info
# RUST_BACKTRACE=1
