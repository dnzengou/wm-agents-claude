# WorldMonitor Core Environment Configuration

# Server Configuration
PORT=8080
DATABASE_URL=sqlite:./worldmonitor.db

# AI API Keys
GROQ_API_KEY=your_groq_api_key_here

# Free Tier Limits
MAX_ALERTS_FREE=3

# Stripe Billing (price tiers: Free / Pro / Enterprise)
# Leave STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET empty to run without billing —
# the checkout endpoint then returns 503 and the UI hides the upgrade CTA.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
# Recurring price ids from the Stripe dashboard (Products → Pricing).
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_price_id
# Public base URL used to build Checkout success/cancel redirect links.
APP_BASE_URL=http://localhost:8080

# Optional: For production deployment
# RUST_LOG=info
# RUST_BACKTRACE=1
